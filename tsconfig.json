{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noEmitOnError": true,
    "rootDir": "extension/src",
    "outDir": "extension/dist/src",
    "types": ["chrome"],
    "skipLibCheck": true
  },
  "include": ["extension/src/**/*.ts"],
  "exclude": ["extension/src/test-fixtures/**/*.ts", "extension/src/**/*.stories.ts", "extension/src/ui/stories/**/*.ts"]
}
