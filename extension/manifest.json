{
  "manifest_version": 3,
  "name": "Image Trail",
  "description": "Inspect and manage image URL transformations from an in-page panel.",
  "version": "0.4.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Toggle Image Trail"
  },
  "commands": {
    "_execute_action": {
      "description": "Open or hide Image Trail panel"
    },
    "shortcut-next": {
      "description": "Next trail step"
    },
    "shortcut-previous": {
      "description": "Previous trail step"
    },
    "shortcut-download": {
      "description": "Download image"
    },
    "shortcut-download-save-as": {
      "description": "Download with Save As"
    },
    "shortcut-slideshow-toggle": {
      "description": "Slideshow"
    },
    "shortcut-stop": {
      "description": "Stop automation"
    },
    "shortcut-grab-mode-toggle": {
      "description": "Grab mode"
    },
    "shortcut-retry": {
      "description": "Retry navigation"
    },
    "toggle-build-info-overlay": {
      "suggested_key": {
        "default": "Alt+Shift+B",
        "mac": "Alt+Shift+B"
      },
      "description": "Toggle build info overlay"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "downloads", "identity", "storage", "declarativeNetRequestWithHostAccess"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "web_accessible_resources": [
    {
      "resources": [
        "src/ui/styles/panel.css",
        "src/ui/styles/fields.css",
        "src/ui/styles/design-system.css",
        "src/ui/styles/primitives.css",
        "src/ui/styles/feedback-primitives.css",
        "src/ui/styles/panel-shell.css",
        "src/ui/styles/primary-workflow.css",
        "src/ui/styles/record-row.css",
        "src/ui/styles/settings-surface.css",
        "src/ui/styles/settings-integrations.css",
        "src/ui/styles/tokens.css"
      ],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
