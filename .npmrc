; madge@8's optional `typescript` peer is pinned to ^5.4.4, which predates this
; repo's TypeScript 6. The peer is optional (madge parses TS via its own bundled
; detective and does not need the root compiler), so npm's default strict peer
; resolution would fail `npm ci` on a purely cosmetic range mismatch. Accept the
; stale optional peer instead of blocking installs. Revisit once madge widens the
; range to include TS 6.
legacy-peer-deps=true
