{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": ".test-dist",
    "types": ["chrome", "node"],
    "noEmit": false,
    "sourceMap": true
  },
  "include": ["extension/src/**/*.ts", "extension/src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx"],
  "exclude": [
    "extension/src/test-fixtures/**/*.ts",
    "extension/src/**/*.stories.ts",
    "extension/src/**/*.stories.tsx",
    "extension/src/ui/stories/**/*.ts",
    "extension/src/ui/stories/**/*.tsx"
  ]
}
